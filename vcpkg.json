{
  "name": "jsengine",
  "version": "0.1.0",
  "dependencies": [
    "quickjs-ng",
    "libvorbis",
    "libogg",
    "opusfile",
    "opus",
    "libvpx",
    "zlib",
    "libpng",
    {
      "name": "freetype",
      "default-features": false,
      "features": ["png", "zlib"]
    },
    "harfbuzz"
  ],
  "vcpkg-configuration": {
    "registries": [
      {
        "kind": "artifact",
        "location": "https://github.com/microsoft/vcpkg-ce-catalog/archive/refs/heads/main.zip",
        "name": "microsoft"
      }
    ]
  }
}
